msgstr "Разрешить маршрут по умолчанию"

#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:133
msgid "Allow forward"
msgstr "Разрешить пересылку"

#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:134
msgid "Allow forward traffic from/to the ZeroTier network."
msgstr "Разрешить пересылку трафика в/из сети ZeroTier."

#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:117
msgid "Allow global IP/route"
msgstr "Разрешить глобальные IP/маршруты"

#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:129
msgid "Allow input"
msgstr "Разрешить входящий"

#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:87
