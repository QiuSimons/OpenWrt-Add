#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:125
msgid "Allow DNS"
msgstr "Разрешить DNS"

#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:126
msgid "Allow ZeroTier to set DNS servers."
msgstr "Разрешить ZeroTier настраивать DNS-серверы."

#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:113
msgid ""
"Allow ZeroTier to set IP addresses and routes (local/private ranges only)."
msgstr "Разрешить ZeroTier задавать IP-адреса и маршруты (только локальные/частные диапазоны)."

#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:118
msgid "Allow ZeroTier to set global/public/not-private range IPs and routes."
msgstr "Разрешить ZeroTier задавать глобальные/публичные (не частные) IP-адреса и маршруты."

#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:122
msgid "Allow ZeroTier to set the default route on the system."
msgstr "Разрешить ZeroTier устанавливать маршрут по умолчанию в системе."

#: applications/luci-app-zerotier/htdocs/luci-static/resources/view/zerotier/config.js:121
