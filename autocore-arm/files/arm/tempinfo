#!/usr/bin/env ucode

let fs = require("fs");

let IEEE_PATH = "/sys/class/ieee80211";
let THERMAL_PATH = "/sys/class/thermal";

let release_content = fs.readfile("/etc/openwrt_release") || "";
let is_ipq = match(release_content, /ipq40xx|ipq806x/);
let is_ipq40xx = match(release_content, /ipq40xx/);

let wifi_temp_arr = [];
let hwmon_paths = is_ipq 
	? fs.glob(IEEE_PATH + "/phy*/device/hwmon/hwmon*/temp1_input")
	: fs.glob(IEEE_PATH + "/phy*/hwmon*/temp1_input");

if (type(hwmon_paths) == "array") {
	for (let p in hwmon_paths) {
		let t = fs.readfile(p);
		if (t != null) {
			push(wifi_temp_arr, sprintf("%.1f°C", trim(t) / 1000));
		}
	}
}

let wifi_temp = join(" ", wifi_temp_arr);

if (is_ipq40xx) {
	let mt76_temp = "";
	let t = fs.readfile(IEEE_PATH + "/phy0/hwmon0/temp1_input");
	if (t != null) {
		let parts = split(trim(t), ": ");
		if (length(parts) > 1) {
			mt76_temp = sprintf(" %s°C", parts[1]);
		} else {
			mt76_temp = " °C";
		}
	}
	
	print(sprintf("WiFi:%s %s", mt76_temp, wifi_temp));
} else {
	let cpu_temp = "";
	let t = fs.readfile(THERMAL_PATH + "/thermal_zone0/temp");
	if (t != null) {
		cpu_temp = sprintf("%.1f°C", trim(t) / 1000);
	}
	
	print(sprintf("CPU: %s, WiFi: %s", cpu_temp, wifi_temp));
}
