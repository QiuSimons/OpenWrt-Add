#!/usr/bin/env ucode

let ubus = require("ubus");
let conn = ubus.connect();

let eth_info = [];

if (conn) {
	let stat = conn.call("network.device", "status");
	if (type(stat) == "object") {
		for (let ifname in stat) {
			if (match(ifname, /^eth\d+$/) || match(ifname, /^usb\d+$/) || match(ifname, /^lan\d+$/) || ifname == "wan") {
				push(eth_info, {
					device: ifname
				});
			}
		}
	}
}

sort(eth_info, function(a, b) {
	if (a.device < b.device) return -1;
	if (a.device > b.device) return 1;
	return 0;
});

print(sprintf("%J\n", eth_info));
