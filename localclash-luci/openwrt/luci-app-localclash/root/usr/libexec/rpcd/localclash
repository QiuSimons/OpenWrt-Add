runtime_start_takeover_run() {
	local tmpdir
	log_line "运行时接管：开始"
	tmpdir="$(mktemp -d /tmp/localclash-runtime.XXXXXX)" || {
		log_line "运行时接管：临时目录创建失败"
		fail "tmpdir_failed" "无法创建临时 runtime 任务目录。"
		return 1
	}

	log_line "运行时接管：正在启动运行时"
	if ! run_with_heartbeat "运行时接管：正在启动运行时" "$tmpdir/runtime.json" call_core runtime start --json; then
		log_line "运行时接管：运行时启动失败"
		cat "$tmpdir/runtime.json"
		rm -rf "$tmpdir"
		return 1
	fi
	sleep 2
	if ! runtime_running; then
		log_line "运行时接管：运行时启动命令已返回成功，但进程没有保持运行"
		fail "runtime_not_running_after_start" "运行时启动命令已返回，但进程没有保持运行。请查看运行日志；常见原因是端口被 OpenClash 或其他服务占用。"
		rm -rf "$tmpdir"
		return 1
	fi

	if takeover_skip_enabled; then
		log_line "运行时接管：测试模式已启用，跳过网络接管"
		printf '{"ok":true,"changed":true,"summary":"运行时已启动；测试模式已跳过网络接管。","runtime":%s,"takeover":{"ok":true,"changed":false,"skipped":true,"summary":"测试模式已跳过网络接管。"}}\n' "$(cat "$tmpdir/runtime.json")"
		rm -rf "$tmpdir"
		return 0
	fi

	log_line "运行时接管：正在应用网络接管"
	if ! run_with_heartbeat "运行时接管：正在应用网络接管" "$tmpdir/takeover.json" call_core takeover apply --json; then
		log_line "运行时接管：网络接管应用失败"
		log_line "运行时接管：正在撤销可能残留的网络接管"
		if call_core takeover stop --json > "$tmpdir/takeover-stop.json"; then
			log_line "运行时接管：网络接管撤销完成"
		else
			log_line "运行时接管：网络接管撤销也失败"
		fi
		log_line "运行时接管：网络接管失败后正在停止运行时"
		runtime_stop > "$tmpdir/runtime-stop.json" 2>/dev/null || log_line "运行时接管：失败后停止运行时也失败"
		cat "$tmpdir/takeover.json"
		rm -rf "$tmpdir"
		return 1
	fi

	log_line "运行时接管：已完成"
	takeover_repair_ticket_enable
	printf '{"ok":true,"changed":true,"summary":"运行时已启动，网络接管已应用。","runtime":%s,"takeover":%s}\n' "$(cat "$tmpdir/runtime.json")" "$(cat "$tmpdir/takeover.json")"
	rm -rf "$tmpdir"
}

takeover_apply() {
	local tmp rc
	if takeover_skip_enabled; then
		fail "takeover_skipped_for_test" "测试模式已启用，已阻止网络接管。删除 /tmp/localclash-skip-takeover 后才允许应用网络接管。"
		return 1
	fi

	tmp="/tmp/localclash-takeover-apply.$$.json"
	if call_core takeover apply --json > "$tmp"; then
		takeover_repair_ticket_enable
		cat "$tmp"
		rm -f "$tmp"
		return 0
	fi
	rc=$?
	cat "$tmp" 2>/dev/null || true
	rm -f "$tmp"
	return "$rc"
}

takeover_stop() {
	local tmp rc
	tmp="/tmp/localclash-takeover-stop.$$.json"
	if call_core takeover stop --json > "$tmp"; then
		takeover_repair_ticket_disable
		cat "$tmp"
		rm -f "$tmp"
		return 0
	fi
	rc=$?
	cat "$tmp" 2>/dev/null || true
	rm -f "$tmp"
	return "$rc"
}

takeover_restore_run() {
	local tmpdir effective runtime_running profile_mode rc
	if takeover_skip_enabled; then
		log_line "网络接管恢复：测试模式已启用，跳过"
		ok '"changed":false,"skipped":true,"summary":"测试模式已启用，跳过网络接管恢复。"'
		return 0
	fi
	if ! takeover_restore_requested; then
		log_line "网络接管恢复：没有本次开机修复票据，跳过"
		ok '"changed":false,"skipped":true,"summary":"没有本次开机网络接管修复票据，跳过恢复。"'
		return 0
	fi

	tmpdir="$(mktemp -d /tmp/localclash-restore.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建网络接管恢复临时目录。"
		return 1
	}

	log_line "网络接管恢复：检查当前状态"
	if ! call_core takeover status --json > "$tmpdir/status.json"; then
		rc=$?
		log_line "网络接管恢复：状态检查失败"
		cat "$tmpdir/status.json" 2>/dev/null || true
		rm -rf "$tmpdir"
		return "$rc"
	fi

	effective="$(jsonfilter -i "$tmpdir/status.json" -e '@.status.effective' 2>/dev/null || true)"
	runtime_running="$(jsonfilter -i "$tmpdir/status.json" -e '@.status.runtime_running' 2>/dev/null || true)"
	profile_mode="$(jsonfilter -i "$tmpdir/status.json" -e '@.status.profile_mode' 2>/dev/null || true)"

	if [ "$effective" = "true" ]; then
		log_line "网络接管恢复：当前已生效"
		takeover_repair_ticket_enable
		printf '{"ok":true,"changed":false,"summary":"网络接管当前已生效。","status":%s}\n' "$(cat "$tmpdir/status.json")"
		rm -rf "$tmpdir"
		return 0
	fi

	if [ "$profile_mode" != "router" ]; then
		log_line "网络接管恢复：当前不是 router profile，跳过"
		printf '{"ok":true,"changed":false,"skipped":true,"summary":"当前不是 router profile，跳过网络接管恢复。","status":%s}\n' "$(cat "$tmpdir/status.json")"
		rm -rf "$tmpdir"
		return 0
	fi

	if [ "$runtime_running" = "true" ]; then
		log_line "网络接管恢复：运行时已运行，重新应用接管"
		if ! call_core takeover apply --json > "$tmpdir/apply.json"; then
			rc=$?
			log_line "网络接管恢复：重新应用接管失败"
			cat "$tmpdir/apply.json" 2>/dev/null || true
			rm -rf "$tmpdir"
			return "$rc"
		fi
		takeover_repair_ticket_enable
		printf '{"ok":true,"changed":true,"summary":"网络接管已重新应用。","status":%s,"takeover":%s}\n' "$(cat "$tmpdir/status.json")" "$(cat "$tmpdir/apply.json")"
		rm -rf "$tmpdir"
		return 0
	fi

	log_line "网络接管恢复：运行时未运行，本次开机修复不会启动运行时"
	printf '{"ok":true,"changed":false,"skipped":true,"summary":"运行时未运行，本次开机修复不会启动运行时。","status":%s}\n' "$(cat "$tmpdir/status.json")"
	rm -rf "$tmpdir"
}

boot_restore_startup_allowed() {
	local max_uptime uptime
	max_uptime="$BOOT_RESTORE_MAX_UPTIME"
	case "$max_uptime" in
		""|*[!0-9]*) max_uptime=300 ;;
	esac
	[ "$max_uptime" -eq 0 ] && return 0
	uptime="$(cut -d. -f1 "$PROC_UPTIME" 2>/dev/null || printf '0')"
	case "$uptime" in
		""|*[!0-9]*) uptime=0 ;;
	esac
	[ "$uptime" -le "$max_uptime" ]
}

boot_restore_startup_run() {
	if ! boot_restore_startup_allowed; then
		log_line "开机自动恢复：当前不是开机窗口，跳过"
		ok '"changed":false,"skipped":true,"summary":"当前不是开机自动恢复窗口，跳过。",'"$(boot_restore_json)"
		return 0
	fi
	boot_restore_run
}

boot_restore_run() {
	if ! boot_auto_restore_enabled; then
		log_line "开机自动恢复：未启用，跳过"
		ok '"changed":false,"skipped":true,"summary":"开机自动恢复未启用。",'"$(boot_restore_json)"
		return 0
	fi
	if takeover_skip_enabled; then
		log_line "开机自动恢复：测试模式已启用，跳过"
		ok '"changed":false,"skipped":true,"summary":"测试模式已启用，跳过开机自动恢复。",'"$(boot_restore_json)"
		return 0
	fi
	log_line "开机自动恢复：开始"
	runtime_start_takeover_run
}

