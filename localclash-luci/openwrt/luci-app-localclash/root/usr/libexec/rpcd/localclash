bootstrap_core() {
	local arch tmpdir manifest binary asset_url asset_sha asset_version tmp_core
	log_line "核心初始化：开始"
	if ! command -v jsonfilter >/dev/null 2>&1; then
		log_line "核心初始化：缺少 jsonfilter"
		fail "jsonfilter_missing" "需要 jsonfilter 解析 localClash Release 清单。"
		return 1
	fi
	arch="$(router_arch)" || {
		log_line "核心初始化：不支持的架构 $(uname -m)"
		fail "unsupported_arch" "localClash 初始化助手不支持此路由器架构。"
		return 1
	}
	tmpdir="$(mktemp -d /tmp/localclash-bootstrap.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建临时初始化目录。"
		return 1
	}
	manifest="$tmpdir/manifest.json"
	binary="$tmpdir/localclash"
	log_line "核心初始化：正在下载 Release 清单"
	if ! fetch_manifest "$MANIFEST_URL" "$manifest"; then
		rm -rf "$tmpdir"
		log_line "核心初始化：Release 清单下载失败"
		fail "manifest_download_failed" "无法下载 localClash Release 清单。"
		return 1
	fi
	asset_url="$(jsonfilter -i "$manifest" -e "@.assets[@.arch=\"$arch\"].url" 2>/dev/null)"
	asset_sha="$(jsonfilter -i "$manifest" -e "@.assets[@.arch=\"$arch\"].sha256" 2>/dev/null)"
	asset_version="$(jsonfilter -i "$manifest" -e "@.version" 2>/dev/null)"
	if [ -z "$asset_url" ] || [ -z "$asset_sha" ]; then
		rm -rf "$tmpdir"
		log_line "核心初始化：Release 清单中没有 $arch 可用文件"
		fail "manifest_asset_missing" "Release 清单中没有匹配此路由器的 Linux 二进制文件。"
		return 1
	fi
	log_line "核心初始化：正在下载 localClash 核心 ${asset_version}（${arch}）"
	if ! fetch_url_verified "$asset_url" "$binary" "$asset_sha"; then
		rm -rf "$tmpdir"
		log_line "核心初始化：核心下载失败"
		fail "core_download_failed" "无法下载 localClash 核心二进制文件。"
		return 1
	fi
	log_line "核心初始化：sha256 校验通过"
	chmod 755 "$binary"
	mkdir -p "$(dirname "$CORE")"
	tmp_core="$CORE.tmp.$$"
	log_line "核心初始化：正在安装 localClash 核心"
	if ! cp "$binary" "$tmp_core" || ! chmod 755 "$tmp_core" || ! mv "$tmp_core" "$CORE"; then
		rm -f "$tmp_core"
		rm -rf "$tmpdir"
		log_line "核心初始化：核心安装失败"
		fail "core_install_failed" "无法安装 localClash 核心二进制文件。"
		return 1
	fi
	if ! install_base_assets "$manifest" "$tmpdir"; then
		rm -rf "$tmpdir"
		return 1
	fi
	rm -rf "$tmpdir"
	if ! service_start >/dev/null; then
		rm -rf "$tmpdir"
		log_line "核心初始化：MCP 服务启动失败"
		fail "service_start_failed" "localClash 核心已安装，但 MCP 服务无法启动。"
		return 1
	fi
	log_line "已安装 localClash 核心 ${asset_version}（${arch}）"
	ok "\"changed\":true,\"summary\":\"localClash 核心已安装。\",\"core\":{\"installed\":true,\"path\":\"$CORE\",\"version\":\"$(json_escape "$asset_version")\",\"arch\":\"$arch\"}"
}

install_base_assets() {
	local output
	output="/tmp/localclash-base-assets.$$.json"
	if ! core_installed; then
		fail "bootstrap_core_missing" "localClash 核心尚未安装，无法初始化基础文件。"
		return 1
	fi
	mkdir -p "$STATE_DIR"
	log_line "基础文件初始化：交由 localClash 核心安装基础文件"
