	log_line "运行时接管：已加入后台任务队列"
	(
		result="$("$0" call runtime_start_takeover_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"运行时启动和网络接管任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		write_task_done "$rc" "$result"
		rm -f "$TASK_PID"
	) >/dev/null 2>&1 &
	bg_pid="$!"
	write_task_pid "$bg_pid"
	ok '"started":true,"running":true,"summary":"运行时启动和网络接管任务已启动。"'
