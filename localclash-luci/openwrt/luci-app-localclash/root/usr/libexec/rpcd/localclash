component_update() {
	local payload component tmp rc
	payload="$(cat)"
	component="$(jsonfilter -s "$payload" -e '@.component' 2>/dev/null)"
	case "$component" in
		localclash) bootstrap_core ;;
		mihomo|dashboard)
			tmp="/tmp/localclash-component-$component.$$.json"
			log_line "组件更新：正在更新 $component"
			if run_with_heartbeat "组件更新：正在更新 $component" "$tmp" call_core component update "$component" --json; then
				log_line "组件更新：$component 已完成"
				cat "$tmp"
				rm -f "$tmp"
				return 0
			fi
			rc=$?
			log_line "组件更新：$component 更新失败"
			cat "$tmp"
			rm -f "$tmp"
			return "$rc"
			;;
		*) fail "invalid_component" "component 必须是 localclash、mihomo 或 dashboard。" ;;
	esac
}

start_one_click_update() {
	local result rc bg_pid payload
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	payload="$(strip_ubus_rpc_session "$(cat)")"
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT" "$TASK_PID"
	: > "$LOG"
	write_versioned_payload "$payload" > "$TASK_INPUT"
	write_task_running "一键更新任务正在运行。" "one_click_update"
	log_line "一键更新：已加入后台任务队列"
	(
		result="$("$0" call one_click_update_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"一键更新任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		write_task_done "$rc" "$result"
		rm -f "$TASK_INPUT" "$TASK_PID"
		if [ "$rc" -eq 0 ] && one_click_update_luci_changed "$result"; then
			luci_schedule_service_reload
		fi
	) >/dev/null 2>&1 &
	bg_pid="$!"
	write_task_pid "$bg_pid"
	ok '"started":true,"running":true,"summary":"一键更新任务已启动。准备阶段不会停止当前运行时；只有最终切换运行时时可能短暂断网。"'
}

one_click_update_run() {
	local tmpdir payload sync_default_policy runtime_was_running takeover_was_effective profile_mode subscription_ready subscription_refresh_failed subscription_cache_used subscription_refresh_json policy_template_sync_json mihomo_changed dashboard_changed restart_strategy runtime_recovered takeover_recovered mcp_healthy current_mode current_core
	payload='{"version":1}'
	if [ -f "$TASK_INPUT" ]; then
		payload="$(cat "$TASK_INPUT" 2>/dev/null || printf '{"version":1}')"
	fi
	sync_default_policy="$(jsonfilter -s "$payload" -e '@.sync_default_policy' 2>/dev/null || true)"
	case "$sync_default_policy" in
		true|false)
			sync_default_policy="$(one_click_update_preferences_set_value "$sync_default_policy")" || {
				printf '%s\n' "$sync_default_policy"
				return 1
			}
			sync_default_policy="$(jsonfilter -s "$sync_default_policy" -e '@.preferences.one_click_update.sync_default_policy' 2>/dev/null || true)"
			;;
		"")
			sync_default_policy="$(one_click_update_sync_default_policy_preference)" || {
				printf '%s\n' "$sync_default_policy"
				return 1
			}
			;;
		*)
			fail_with_details "invalid_one_click_update_input" "sync_default_policy 必须是 true 或 false。" '"sync_default_policy":"'"$(json_escape "$sync_default_policy")"'"'
			return 1
			;;
	esac
	case "$sync_default_policy" in
		true|false) ;;
		*)
			fail_with_details "invalid_one_click_update_preferences" "一键更新偏好文件无效，请删除后重新设置。" '"sync_default_policy":"'"$(json_escape "$sync_default_policy")"'"'
			return 1
			;;
	esac
	runtime_was_running=false
	takeover_was_effective=false
	profile_mode=""
	subscription_ready=false
	subscription_refresh_failed=false
	subscription_cache_used=false
	subscription_refresh_json='null'
	policy_template_sync_json='{"ok":true,"changed":false,"skipped":true,"summary":"未选择同步最新默认策略。"}'
	mihomo_changed=false
	dashboard_changed=false
	restart_strategy="skipped"
	runtime_recovered=false
	takeover_recovered=false

	log_line "一键更新：开始"
	tmpdir="$(mktemp -d /tmp/localclash-one-click-update.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建一键更新临时目录。"
		return 1
	}

	if core_installed; then
		log_line "一键更新：记录更新前运行时状态"
		if ! call_core runtime status --json > "$tmpdir/runtime-before.json"; then
			log_line "一键更新：运行时状态读取失败"
			cat "$tmpdir/runtime-before.json" 2>/dev/null || true
			rm -rf "$tmpdir"
			return 1
		fi
		runtime_was_running="$(json_bool_required "$tmpdir/runtime-before.json" '@.status.running' "runtime_status_invalid" "无法读取更新前运行时状态。")" || {
			printf '%s\n' "$runtime_was_running"
			rm -rf "$tmpdir"
			return 1
		}

		log_line "一键更新：记录更新前网络接管状态"
		if ! call_core takeover status --json > "$tmpdir/takeover-before.json"; then
			log_line "一键更新：网络接管状态读取失败"
			cat "$tmpdir/takeover-before.json" 2>/dev/null || true
			rm -rf "$tmpdir"
			return 1
		fi
		takeover_was_effective="$(json_bool_required "$tmpdir/takeover-before.json" '@.status.effective' "takeover_status_invalid" "无法读取更新前网络接管状态。")" || {
			printf '%s\n' "$takeover_was_effective"
			rm -rf "$tmpdir"
			return 1
		}
		profile_mode="$(jsonfilter -i "$tmpdir/takeover-before.json" -e '@.status.profile_mode' 2>/dev/null || true)"
	else
		log_line "一键更新：localClash 核心尚未安装，跳过运行时快照"
	fi

	log_line "一键更新：准备阶段开始，当前运行时保持不动"
	if ! run_with_heartbeat "一键更新：正在更新 LuCI 界面" "$tmpdir/luci.json" luci_update; then
		log_line "一键更新：LuCI 更新失败"
		cat "$tmpdir/luci.json"
		rm -rf "$tmpdir"
		return 1
	fi

	if ! run_with_heartbeat "一键更新：正在更新 localClash 核心" "$tmpdir/core.json" bootstrap_core; then
		log_line "一键更新：localClash 核心更新失败"
		cat "$tmpdir/core.json"
		rm -rf "$tmpdir"
		return 1
	fi

	if ! service_status > "$tmpdir/mcp-service.json"; then
		log_line "一键更新：MCP 服务状态读取失败"
		cat "$tmpdir/mcp-service.json"
		rm -rf "$tmpdir"
		return 1
	fi
	mcp_healthy="$(json_bool_required "$tmpdir/mcp-service.json" '@.mcp.healthy' "mcp_service_status_invalid" "无法读取 MCP 服务健康状态。")" || {
		printf '%s\n' "$mcp_healthy"
		rm -rf "$tmpdir"
		return 1
	}
	if [ "$mcp_healthy" != "true" ]; then
		log_line "一键更新：MCP 服务健康检查未通过"
		fail "mcp_service_unhealthy" "localClash 核心已更新，但 MCP 服务健康检查未通过。"
		rm -rf "$tmpdir"
		return 1
	fi

	if ! run_with_heartbeat "一键更新：正在更新 Mihomo 核心" "$tmpdir/mihomo.json" call_core component update mihomo --json; then
		log_line "一键更新：Mihomo 核心更新失败"
		cat "$tmpdir/mihomo.json"
		rm -rf "$tmpdir"
		return 1
	fi
	mihomo_changed="$(json_bool_required "$tmpdir/mihomo.json" '@.changed' "component_update_result_invalid" "无法读取 Mihomo 核心更新结果。")" || {
		printf '%s\n' "$mihomo_changed"
		rm -rf "$tmpdir"
		return 1
	}

	if ! run_with_heartbeat "一键更新：正在更新 Dashboard" "$tmpdir/dashboard.json" call_core component update dashboard --json; then
		log_line "一键更新：Dashboard 更新失败"
		cat "$tmpdir/dashboard.json"
		rm -rf "$tmpdir"
		return 1
	fi
	dashboard_changed="$(json_bool_required "$tmpdir/dashboard.json" '@.changed' "component_update_result_invalid" "无法读取 Dashboard 更新结果。")" || {
		printf '%s\n' "$dashboard_changed"
		rm -rf "$tmpdir"
		return 1
	}

	if [ "$sync_default_policy" = "true" ]; then
		log_line "一键更新：准备同步最新默认策略"
		if ! call_core config status --json > "$tmpdir/config-status.json"; then
			log_line "一键更新：配置状态读取失败，无法同步默认策略"
			cat "$tmpdir/config-status.json" 2>/dev/null || true
			rm -rf "$tmpdir"
			return 1
		fi
		current_mode="$(jsonfilter -i "$tmpdir/config-status.json" -e '@.status.runtime_profile.mode' 2>/dev/null || true)"
		current_core="$(jsonfilter -i "$tmpdir/config-status.json" -e '@.status.runtime_profile.core' 2>/dev/null || true)"
		case "$current_mode" in
			normal|router) ;;
			*)
				fail_with_details "runtime_profile_status_invalid" "无法读取当前 runtime profile mode，已停止同步默认策略。" '"mode":"'"$(json_escape "$current_mode")"'"'
				rm -rf "$tmpdir"
				return 1
				;;
		esac
		case "$current_core" in
			meta|smart) ;;
			*)
				fail_with_details "runtime_profile_status_invalid" "无法读取当前 runtime core，已停止同步默认策略。" '"core":"'"$(json_escape "$current_core")"'"'
				rm -rf "$tmpdir"
				return 1
				;;
		esac
		cat > "$tmpdir/template-sync.json" <<JSON
{
  "version": 1,
  "template": "localclash-default",
  "runtime_profile": "$current_mode",
  "core": "$current_core",
  "allow_overwrite_modified": true,
  "refresh_policy_template_patches": true
}
JSON
		if ! run_with_heartbeat "一键更新：正在同步最新默认策略" "$tmpdir/policy-template-sync.json" call_core config apply-template --input "$tmpdir/template-sync.json" --json; then
			log_line "一键更新：默认策略同步失败"
			cat "$tmpdir/policy-template-sync.json"
			rm -rf "$tmpdir"
			return 1
		fi
		policy_template_sync_json="$(cat "$tmpdir/policy-template-sync.json")"
	else
		log_line "一键更新：未选择同步最新默认策略"
	fi

	log_line "一键更新：检查已保存订阅"
	if ! call_core subscription status --json > "$tmpdir/subscription-status.json"; then
		log_line "一键更新：订阅状态读取失败"
		cat "$tmpdir/subscription-status.json" 2>/dev/null || true
		rm -rf "$tmpdir"
		return 1
	fi
	subscription_ready="$(json_bool_required "$tmpdir/subscription-status.json" '@.status.configured' "subscription_status_invalid" "无法读取订阅配置状态。")" || {
		printf '%s\n' "$subscription_ready"
		rm -rf "$tmpdir"
		return 1
	}

	if [ "$subscription_ready" = "true" ]; then
		if ! run_with_heartbeat "一键更新：正在刷新订阅" "$tmpdir/subscription-refresh.json" call_core subscription refresh --json; then
			subscription_refresh_failed=true
			subscription_cache_used=true
			subscription_refresh_json="$(printf '{"ok":false,"changed":false,"summary":"订阅刷新失败，已使用缓存订阅继续。","fallback_reason":"一键更新需要在组件更新后尽量恢复可用运行时；订阅源临时不可用时，只要现有缓存订阅还能通过配置生成和 Mihomo 配置验证，就继续完成运行时切换和接管恢复。","output":"%s"}' "$(json_escape "$(tr '\n\r' '  ' < "$tmpdir/subscription-refresh.json" 2>/dev/null)")")"
			# Fallback reason: one-click update is an availability-recovery flow.
			# A transient subscription source outage should not block runtime restart
			# when the existing merged subscription cache can still render and pass
			# config-test below. If the cache is missing or invalid, config render or
			# mihomo config-test still fails explicitly instead of guessing state.
			log_line "一键更新：订阅刷新失败，使用已保存的订阅缓存继续"
			cat "$tmpdir/subscription-refresh.json" >&2
		else
			subscription_refresh_json="$(cat "$tmpdir/subscription-refresh.json")"
		fi
		if ! run_with_heartbeat "一键更新：正在生成 Mihomo 配置" "$tmpdir/render.json" call_core config render --json; then
			log_line "一键更新：配置生成失败"
			cat "$tmpdir/render.json"
			rm -rf "$tmpdir"
			return 1
		fi
	else
		subscription_refresh_json='{"ok":true,"changed":false,"summary":"未配置订阅，跳过订阅刷新。","skipped":true}'
		log_line "一键更新：未配置订阅，跳过订阅刷新和配置重建"
	fi

	if [ "$subscription_ready" = "true" ] || [ "$runtime_was_running" = "true" ]; then
		if ! run_with_heartbeat "一键更新：正在验证 Mihomo 配置" "$tmpdir/config-test.json" call_core mihomo config-test --json; then
			log_line "一键更新：Mihomo 配置验证失败"
			cat "$tmpdir/config-test.json"
			rm -rf "$tmpdir"
			return 1
		fi
	else
		log_line "一键更新：没有订阅且更新前运行时未运行，跳过配置验证"
	fi

	if [ "$runtime_was_running" = "true" ]; then
		restart_strategy="hot_reload"
		if [ "$mihomo_changed" = "true" ]; then
			restart_strategy="process_restart"
		fi
		log_line "一键更新：进入最短断网切换窗口，策略 ${restart_strategy}"
		if ! run_with_heartbeat "一键更新：正在切换运行时" "$tmpdir/runtime-restart.json" call_core runtime restart --strategy "$restart_strategy" --json; then
			log_line "一键更新：运行时切换失败"
			cat "$tmpdir/runtime-restart.json"
			rm -rf "$tmpdir"
			return 1
		fi
		runtime_recovered=true
	else
		log_line "一键更新：更新前运行时未运行，跳过运行时切换"
	fi

	if [ "$takeover_was_effective" = "true" ]; then
		if [ "$profile_mode" != "router" ]; then
			log_line "一键更新：更新前接管有效但 profile 不是 router，拒绝猜测恢复路径"
			fail_with_details "takeover_snapshot_inconsistent" "更新前网络接管有效，但 runtime profile 不是 router，已停止在接管恢复前。" '"profile_mode":"'"$(json_escape "$profile_mode")"'"'
			rm -rf "$tmpdir"
			return 1
		fi
		log_line "一键更新：恢复网络接管"
		if ! run_with_heartbeat "一键更新：正在恢复网络接管" "$tmpdir/takeover-apply.json" takeover_apply; then
			log_line "一键更新：网络接管恢复失败"
			cat "$tmpdir/takeover-apply.json"
			rm -rf "$tmpdir"
			return 1
		fi
		if ! call_core takeover status --json > "$tmpdir/takeover-after.json"; then
			log_line "一键更新：接管恢复后状态读取失败"
			cat "$tmpdir/takeover-after.json" 2>/dev/null || true
			rm -rf "$tmpdir"
			return 1
		fi
		takeover_recovered="$(json_bool_required "$tmpdir/takeover-after.json" '@.status.effective' "takeover_status_invalid" "无法读取更新后网络接管状态。")" || {
			printf '%s\n' "$takeover_recovered"
			rm -rf "$tmpdir"
			return 1
		}
		if [ "$takeover_recovered" != "true" ]; then
			log_line "一键更新：接管恢复后仍未生效"
			fail "takeover_restore_failed" "更新已完成，但网络接管恢复后仍未生效。"
			rm -rf "$tmpdir"
			return 1
		fi
	else
		log_line "一键更新：更新前网络接管未生效，跳过接管恢复"
	fi

	if ! service_status > "$tmpdir/mcp-service-final.json"; then
		log_line "一键更新：最终 MCP 服务状态读取失败"
		cat "$tmpdir/mcp-service-final.json"
		rm -rf "$tmpdir"
		return 1
	fi
	mcp_healthy="$(json_bool_required "$tmpdir/mcp-service-final.json" '@.mcp.healthy' "mcp_service_status_invalid" "无法读取最终 MCP 服务健康状态。")" || {
		printf '%s\n' "$mcp_healthy"
		rm -rf "$tmpdir"
		return 1
	}
	if [ "$mcp_healthy" != "true" ]; then
		log_line "一键更新：最终 MCP 服务健康检查未通过"
		fail "mcp_service_unhealthy" "一键更新已执行，但 MCP 服务健康检查未通过。"
		rm -rf "$tmpdir"
		return 1
	fi

	log_line "一键更新：已完成"
	printf '{"ok":true,"changed":true,"summary":"一键更新已完成。","minimal_outage":{"runtime_kept_until_final_switch":true,"restart_strategy":"%s","runtime_was_running":%s,"runtime_recovered":%s,"takeover_was_effective":%s,"takeover_recovered":%s},"luci":%s,"core":%s,"mihomo":%s,"dashboard":%s,"policy_template_sync":%s,"subscription":{"configured":%s,"refresh_failed":%s,"used_cached_artifact":%s,"refresh":%s},"mcp_service":%s}\n' \
		"$(json_escape "$restart_strategy")" \
		"$runtime_was_running" \
		"$runtime_recovered" \
		"$takeover_was_effective" \
		"$takeover_recovered" \
		"$(cat "$tmpdir/luci.json")" \
		"$(cat "$tmpdir/core.json")" \
		"$(cat "$tmpdir/mihomo.json")" \
		"$(cat "$tmpdir/dashboard.json")" \
		"$policy_template_sync_json" \
		"$subscription_ready" \
		"$subscription_refresh_failed" \
		"$subscription_cache_used" \
		"$subscription_refresh_json" \
		"$(cat "$tmpdir/mcp-service-final.json")"
	rm -rf "$tmpdir"
}

start_bootstrap_core() {
	local result rc bg_pid
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT" "$TASK_PID"
	: > "$LOG"
	write_task_running "localClash 核心更新任务正在运行。" "bootstrap_core"
	log_line "核心初始化：已加入后台任务队列"
	(
		result="$("$0" call bootstrap_core_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"localClash 核心更新任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		write_task_done "$rc" "$result"
		rm -f "$TASK_PID"
	) >/dev/null 2>&1 &
	bg_pid="$!"
	write_task_pid "$bg_pid"
	ok '"started":true,"running":true,"summary":"localClash 核心更新任务已启动。"'
}

start_component_update() {
	local payload component result rc bg_pid
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	payload="$(strip_ubus_rpc_session "$(cat)")"
	component="$(jsonfilter -s "$payload" -e '@.component' 2>/dev/null)"
	case "$component" in
		localclash|mihomo|dashboard) ;;
		*) fail "invalid_component" "component 必须是 localclash、mihomo 或 dashboard。"; return 1 ;;
	esac
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT" "$TASK_PID"
	: > "$LOG"
	printf '%s\n' "$payload" > "$TASK_INPUT"
	write_task_running "组件更新任务正在运行。" "component_update"
	log_line "组件更新：$component 已加入后台任务队列"
	(
		result="$("$0" call component_update_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"组件更新任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		write_task_done "$rc" "$result"
		rm -f "$TASK_INPUT" "$TASK_PID"
	) >/dev/null 2>&1 &
	bg_pid="$!"
	write_task_pid "$bg_pid"
	ok '"started":true,"running":true,"summary":"组件更新任务已启动。"'
}

component_update_run() {
	if [ ! -f "$TASK_INPUT" ]; then
		fail "task_input_missing" "组件更新任务输入缺失。"
		return 1
	fi
	with_lock component_update < "$TASK_INPUT"
}

start_luci_update() {
	local result rc bg_pid
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT" "$TASK_PID"
	: > "$LOG"
	write_task_running "LuCI 界面更新任务正在运行。" "luci_update"
	log_line "LuCI 更新：已加入后台任务队列"
	(
		result="$("$0" call luci_update_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"LuCI 更新任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		write_task_done "$rc" "$result"
		rm -f "$TASK_PID"
		if [ "$rc" -eq 0 ] && luci_update_changed "$result"; then
			luci_schedule_service_reload
		fi
	) >/dev/null 2>&1 &
	bg_pid="$!"
	write_task_pid "$bg_pid"
	ok '"started":true,"running":true,"summary":"LuCI 界面更新任务已启动。"'
}

luci_update_run() {
	with_lock luci_update
}

input_to_core_file() {
	local payload tmp rc
	payload="$(cat)"
	payload="$(strip_ubus_rpc_session "$payload")"
	tmp="/tmp/localclash-input-$$.json"
	write_versioned_payload "$payload" > "$tmp"
	call_core "$@" --input "$tmp" --json
	rc=$?
	rm -f "$tmp"
	return "$rc"
}

strip_ubus_rpc_session() {
	printf '%s' "$1" | sed \
		-e 's/"ubus_rpc_session"[[:space:]]*:[[:space:]]*"[^"]*"[[:space:]]*,[[:space:]]*//' \
		-e 's/,[[:space:]]*"ubus_rpc_session"[[:space:]]*:[[:space:]]*"[^"]*"//' \
		-e 's/{[[:space:]]*"ubus_rpc_session"[[:space:]]*:[[:space:]]*"[^"]*"[[:space:]]*}/{}/'
}

write_versioned_payload() {
	local payload body
	payload="$1"
	if printf '%s' "$payload" | jsonfilter -e '@.version' >/dev/null 2>&1; then
		printf '%s' "$payload"
		return 0
	fi

	body="$(printf '%s' "$payload" | sed 's/^[[:space:]]*{//; s/}[[:space:]]*$//')"
	if [ -n "$body" ]; then
		printf '{"version":1,%s}' "$body"
	else
		printf '{"version":1}'
	fi
}

subscription_set() {
	input_to_core_file subscription set
}

subscription_get() {
	local tmp configured uris urls count uri uris_file urls_file
	uris=""
	urls=""
	count=0

	if ! core_installed; then
		ok '"configured":false,"uris":[],"urls":[],"count":0'
		return 0
	fi

	tmp="/tmp/localclash-subscription-get.$$.json"
	if ! call_core subscription get --json > "$tmp" 2>/dev/null; then
		rm -f "$tmp"
		ok '"configured":false,"uris":[],"urls":[],"count":0'
		return 0
	fi
	configured="$(jsonfilter -i "$tmp" -e '@.status.configured' 2>/dev/null || printf false)"
	if [ "$configured" != "true" ]; then
		rm -f "$tmp"
		ok '"configured":false,"uris":[],"urls":[],"count":0'
		return 0
	fi

	uris_file="$tmp.uris"
	urls_file="$tmp.urls"
	jsonfilter -i "$tmp" -e '@.status.uris[*]' > "$uris_file" 2>/dev/null || true
	while IFS= read -r uri; do
		[ -n "$uri" ] || continue
		if [ "$count" -gt 0 ]; then
			uris="$uris,"
		fi
		uris="$uris\"$(json_escape "$uri")\""
		count=$((count + 1))
	done < "$uris_file"
	jsonfilter -i "$tmp" -e '@.status.urls[*]' > "$urls_file" 2>/dev/null || true
	while IFS= read -r uri; do
		[ -n "$uri" ] || continue
		if [ -n "$urls" ]; then
			urls="$urls,"
		fi
		urls="$urls\"$(json_escape "$uri")\""
	done < "$urls_file"
	rm -f "$tmp" "$uris_file" "$urls_file"

	ok '"configured":true,"uris":['"$uris"'],"urls":['"$urls"'],"count":'"$count"
}

subscription_save_refresh_file() {
	local input tmpdir
	input="$1"
	tmpdir="$2"

	log_line "订阅设置：正在保存订阅源"
	if ! call_core subscription set --input "$input" --json > "$tmpdir/set.json"; then
		cat "$tmpdir/set.json"
		return 1
	fi

	log_line "订阅设置：正在刷新订阅"
	if ! run_with_heartbeat "订阅设置：正在刷新订阅" "$tmpdir/refresh.json" call_core subscription refresh --json; then
		cat "$tmpdir/refresh.json"
		return 1
	fi
}

subscription_setup_file() {
	local input tmpdir
	input="$1"
	tmpdir="$(mktemp -d /tmp/localclash-subscription.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建临时订阅目录。"
		return 1
	}

	if ! subscription_save_refresh_file "$input" "$tmpdir"; then
		rm -rf "$tmpdir"
		return 1
	fi

	log_line "订阅设置：正在生成 Mihomo 配置"
	if ! run_with_heartbeat "订阅设置：正在生成 Mihomo 配置" "$tmpdir/render.json" call_core config render --json; then
		cat "$tmpdir/render.json"
		rm -rf "$tmpdir"
		return 1
	fi

	rm -rf "$tmpdir"
	log_line "订阅设置：已完成"
	ok '"changed":true,"summary":"订阅已保存、刷新，并已生成配置。","next_actions":["准备好后启动运行时。"]'
}

write_bootstrap_subscription_input() {
	local payload output uris_file count uri
	payload="$1"
	output="$2"
	uris_file="$output.uris"
	count=0

	jsonfilter -s "$payload" -e '@.uris[*]' > "$uris_file" 2>/dev/null || true
	if [ ! -s "$uris_file" ]; then
		jsonfilter -s "$payload" -e '@.urls[*]' > "$uris_file" 2>/dev/null || true
	fi
	printf '{"version":1,"uris":[' > "$output"
	while IFS= read -r uri; do
		[ -n "$uri" ] || continue
		if [ "$count" -gt 0 ]; then
			printf ',' >> "$output"
		fi
		printf '"%s"' "$(json_escape "$uri")" >> "$output"
		count=$((count + 1))
	done < "$uris_file"
	printf ']}\n' >> "$output"
	rm -f "$uris_file"

	[ "$count" -gt 0 ]
}

