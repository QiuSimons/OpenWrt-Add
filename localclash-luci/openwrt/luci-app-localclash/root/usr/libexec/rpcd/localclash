#!/bin/sh

CORE="${LOCALCLASH_CORE:-/usr/local/bin/localclash}"
STATE_DIR="${LOCALCLASH_STATE_DIR:-/root/localclash}"
SERVICE="/etc/init.d/localclash-mcp"
LOG="/tmp/localclash-helper.log"
LOCK_DIR="/tmp/localclash-helper.lock"
TASK_STATUS="/tmp/localclash-task-status.json"
TASK_RESULT="/tmp/localclash-task-result.json"
TASK_INPUT="/tmp/localclash-task-input.json"
TASK_PID="/tmp/localclash-task.pid"
MIRROR_CACHE_DIR="/tmp/localclash-mirror-cache"
MCP_ADDR="${LOCALCLASH_MCP_ADDR:-0.0.0.0:8765}"
MCP_HELP="/usr/share/localclash/mcp-help.txt"
MANIFEST_URL="${LOCALCLASH_RELEASE_MANIFEST:-https://github.com/qoli/localClash/releases/latest/download/localclash-release-manifest.json}"
LUCI_RELEASE_API="${LOCALCLASH_LUCI_RELEASE_API:-https://api.github.com/repos/qoli/localclash-luci/releases/latest}"
GITHUB_MIRROR="${LOCALCLASH_GITHUB_MIRROR:-auto}"
GITHUB_RELEASE_MIRRORS="${LOCALCLASH_GITHUB_RELEASE_MIRRORS:-https://gh-proxy.com/https://github.com https://ghproxy.imciel.com/https://github.com https://gitproxy.mrhjx.cn/https://github.com https://gh.jasonzeng.dev/https://github.com https://gh.monlor.com/https://github.com https://gh.noki.icu/https://github.com https://ghfast.top/https://github.com}"
GITHUB_RAW_MIRRORS="${LOCALCLASH_GITHUB_RAW_MIRRORS:-https://gh-proxy.com/https://raw.githubusercontent.com https://ghproxy.imciel.com/https://raw.githubusercontent.com https://gitproxy.mrhjx.cn/https://raw.githubusercontent.com https://gh.jasonzeng.dev/https://raw.githubusercontent.com https://gh.monlor.com/https://raw.githubusercontent.com https://gh.noki.icu/https://raw.githubusercontent.com https://ghfast.top/https://raw.githubusercontent.com https://fastly.jsdelivr.net/gh}"
FETCH_TIMEOUT="${LOCALCLASH_FETCH_TIMEOUT:-20}"
TASK_STEP_TIMEOUT="${LOCALCLASH_TASK_STEP_TIMEOUT:-240}"
TAKEOVER_SKIP_FILE="${LOCALCLASH_TAKEOVER_SKIP_FILE:-/tmp/localclash-skip-takeover}"
TAKEOVER_REPAIR_TICKET="${LOCALCLASH_TAKEOVER_REPAIR_TICKET:-/tmp/localclash/router-takeover/repair-ticket}"
TAKEOVER_STATE_STATUS="${LOCALCLASH_TAKEOVER_STATE_STATUS:-/tmp/localclash/router-takeover/status}"
BOOT_AUTO_RESTORE_FILE="${LOCALCLASH_BOOT_AUTO_RESTORE_FILE:-$STATE_DIR/boot-auto-restore-enabled}"
LEGACY_TAKEOVER_INTENT_FILE="${LOCALCLASH_LEGACY_TAKEOVER_INTENT_FILE:-$STATE_DIR/takeover-enabled}"
BOOT_RESTORE_MAX_UPTIME="${LOCALCLASH_BOOT_RESTORE_MAX_UPTIME:-300}"
PROC_UPTIME="${LOCALCLASH_PROC_UPTIME:-/proc/uptime}"

json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

ok() {
	printf '{"ok":true,%s}\n' "$1"
}

fail() {
	code="$(json_escape "$1")"
	message="$(json_escape "$2")"
	printf '{"ok":false,"code":"%s","message":"%s","details":{},"next_actions":[]}\n' "$code" "$message"
}

fail_with_details() {
	code="$(json_escape "$1")"
	message="$(json_escape "$2")"
	details="$3"
	printf '{"ok":false,"code":"%s","message":"%s","details":{%s},"next_actions":[]}\n' "$code" "$message" "$details"
}

log_line() {
	printf '%s %s\n' "$(date -Iseconds 2>/dev/null || date)" "$*" >> "$LOG"
}

takeover_skip_enabled() {
	[ "${LOCALCLASH_TAKEOVER_SKIP:-0}" = "1" ] || [ -f "$TAKEOVER_SKIP_FILE" ]
}

takeover_repair_ticket_enabled() {
	[ -f "$TAKEOVER_REPAIR_TICKET" ]
}

takeover_runtime_state_enabled() {
	grep -qx 'applied' "$TAKEOVER_STATE_STATUS" 2>/dev/null
}

takeover_restore_requested() {
	takeover_repair_ticket_enabled || takeover_runtime_state_enabled
}

takeover_repair_ticket_enable() {
	mkdir -p "$(dirname "$TAKEOVER_REPAIR_TICKET")" 2>/dev/null || true
	printf 'applied\n' > "$TAKEOVER_REPAIR_TICKET" 2>/dev/null || true
}

takeover_repair_ticket_disable() {
	rm -f "$TAKEOVER_REPAIR_TICKET" "$TAKEOVER_STATE_STATUS" 2>/dev/null || true
}

boot_auto_restore_enabled() {
	[ -f "$BOOT_AUTO_RESTORE_FILE" ]
}

legacy_takeover_marker_present() {
	[ -f "$LEGACY_TAKEOVER_INTENT_FILE" ]
}

boot_restore_json() {
	local enabled legacy
	enabled=false
	legacy=false
	boot_auto_restore_enabled && enabled=true
	legacy_takeover_marker_present && legacy=true
	printf '"boot_auto_restore":{"enabled":%s,"path":"%s","legacy_marker_present":%s,"legacy_path":"%s"}' "$enabled" "$(json_escape "$BOOT_AUTO_RESTORE_FILE")" "$legacy" "$(json_escape "$LEGACY_TAKEOVER_INTENT_FILE")"
}

boot_restore_status() {
	ok "$(boot_restore_json)"
}

one_click_update_preferences_path() {
	local workdir
	if [ -n "${LOCALCLASH_ONE_CLICK_UPDATE_PREFERENCES_FILE:-}" ]; then
		printf '%s\n' "$LOCALCLASH_ONE_CLICK_UPDATE_PREFERENCES_FILE"
		return 0
	fi
	workdir="$(resolve_state_dir)" || return 1
	printf '%s/luci-preferences.json\n' "$workdir"
}

one_click_update_sync_default_policy_preference() {
	local path value
	path="$(one_click_update_preferences_path)" || return 1
	if [ ! -f "$path" ]; then
		printf 'true\n'
		return 0
	fi
	value="$(jsonfilter -i "$path" -e '@.one_click_update.sync_default_policy' 2>/dev/null || true)"
	case "$value" in
		true|false) printf '%s\n' "$value" ;;
		*)
			fail_with_details "invalid_one_click_update_preferences" "一键更新偏好文件无效，请删除后重新设置。" '"path":"'"$(json_escape "$path")"'"'
			return 1
			;;
	esac
}

one_click_update_preferences() {
	local path value defaulted
	path="$(one_click_update_preferences_path)" || {
		printf '%s\n' "$path"
		return 1
	}
	value="$(one_click_update_sync_default_policy_preference)" || {
		printf '%s\n' "$value"
		return 1
	}
	defaulted=false
	[ ! -f "$path" ] && defaulted=true
	ok '"preferences":{"one_click_update":{"sync_default_policy":'"$value"'}},"defaulted":'"$defaulted"',"path":"'"$(json_escape "$path")"'"'
}

one_click_update_preferences_set_value() {
	local value path dir tmp
	value="$1"
	case "$value" in
		true|false) ;;
		*)
			fail_with_details "invalid_one_click_update_preferences_input" "sync_default_policy 必须是 true 或 false。" '"sync_default_policy":"'"$(json_escape "$value")"'"'
			return 1
			;;
	esac
	path="$(one_click_update_preferences_path)" || {
		printf '%s\n' "$path"
		return 1
	}
	dir="$(dirname "$path")"
	if ! mkdir -p "$dir"; then
		fail_with_details "one_click_update_preferences_write_failed" "无法创建一键更新偏好目录。" '"path":"'"$(json_escape "$dir")"'"'
		return 1
	fi
	tmp="${path}.$$"
	umask 077
	if ! printf '{"version":1,"one_click_update":{"sync_default_policy":%s}}\n' "$value" > "$tmp"; then
		rm -f "$tmp"
		fail_with_details "one_click_update_preferences_write_failed" "无法写入一键更新偏好文件。" '"path":"'"$(json_escape "$path")"'"'
		return 1
	fi
	if ! mv "$tmp" "$path"; then
		rm -f "$tmp"
		fail_with_details "one_click_update_preferences_write_failed" "无法保存一键更新偏好文件。" '"path":"'"$(json_escape "$path")"'"'
		return 1
	fi
	ok '"changed":true,"preferences":{"one_click_update":{"sync_default_policy":'"$value"'}},"path":"'"$(json_escape "$path")"'"'
}

one_click_update_preferences_set() {
	local payload value
	payload="$(strip_ubus_rpc_session "$(cat)")"
	value="$(jsonfilter -s "$payload" -e '@.sync_default_policy' 2>/dev/null || true)"
	one_click_update_preferences_set_value "$value"
}

luci_package_json() {
	local installed manager version
	installed=false
	manager=unknown
	version=""
	manager="$(luci_package_manager 2>/dev/null || printf 'unknown\n')"
	if [ "$manager" != "unknown" ]; then
		version="$(luci_installed_package_version "$manager")"
		[ -n "$version" ] && installed=true
	fi
	printf '"luci_package":{"installed":%s,"name":"luci-app-localclash","version":"%s","manager":"%s","latest_url":"https://github.com/qoli/localclash-luci/releases/latest","release_api":"%s"}' "$installed" "$(json_escape "$version")" "$(json_escape "$manager")" "$(json_escape "$LUCI_RELEASE_API")"
}

luci_package_manager() {
	if command -v opkg >/dev/null 2>&1; then
		printf 'opkg\n'
		return 0
	fi
	if command -v apk >/dev/null 2>&1; then
		printf 'apk\n'
		return 0
	fi
	return 1
}

luci_installed_package_version() {
	local manager status
	manager="$1"
	case "$manager" in
		opkg)
			status="$(opkg status luci-app-localclash 2>/dev/null || true)"
			printf '%s\n' "$status" | awk -F': ' '/^Version: / { print $2; exit }'
			;;
		apk)
			apk list -I luci-app-localclash 2>/dev/null | sed -n 's/^luci-app-localclash-\([^ ]*\) .*/\1/p' | head -n 1
			;;
	esac
}

luci_update_asset_url() {
	local release manager asset_regex
	release="$1"
	manager="$2"
	case "$manager" in
		opkg) asset_regex='luci-app-localclash_[^/]*_all[.]ipk$' ;;
		apk) asset_regex='luci-app-localclash-[^/]*[.]apk$' ;;
		*) return 1 ;;
	esac
	jsonfilter -i "$release" -e '@.assets[*].browser_download_url' 2>/dev/null | grep -E "$asset_regex" | grep -v '[.]sha256$' | head -n 1
}

luci_update_asset_version() {
	local manager asset_url name
	manager="$1"
	asset_url="$2"
	name="${asset_url##*/}"
	case "$manager" in
		opkg)
			printf '%s\n' "$name" | sed -n 's/^luci-app-localclash_\(.*\)_all[.]ipk$/\1/p'
			;;
		apk)
			printf '%s\n' "$name" | sed -n 's/^luci-app-localclash-\(.*\)[.]apk$/\1/p'
			;;
	esac
}

luci_update_sha_url() {
	local release manager asset_regex
	release="$1"
	manager="$2"
	case "$manager" in
		opkg) asset_regex='luci-app-localclash_[^/]*_all[.]ipk[.]sha256$' ;;
		apk) asset_regex='luci-app-localclash-[^/]*[.]apk[.]sha256$' ;;
		*) return 1 ;;
	esac
	jsonfilter -i "$release" -e '@.assets[*].browser_download_url' 2>/dev/null | grep -E "$asset_regex" | head -n 1
}

luci_version_relation() {
	local manager current target relation
	manager="$1"
	current="$2"
	target="$3"
	case "$manager" in
		opkg)
			if opkg compare-versions "$current" = "$target"; then
				printf 'equal\n'
				return 0
			fi
			if opkg compare-versions "$target" '>' "$current"; then
				printf 'target_newer\n'
				return 0
			fi
			if opkg compare-versions "$target" '<' "$current"; then
				printf 'target_older\n'
				return 0
			fi
			return 1
			;;
		apk)
			relation="$(apk version -t "$target" "$current" 2>/dev/null)" || return 1
			case "$relation" in
				=) printf 'equal\n' ;;
				'>') printf 'target_newer\n' ;;
				'<') printf 'target_older\n' ;;
				*) return 1 ;;
			esac
			;;
		*) return 1 ;;
	esac
}

luci_install_log_excerpt() {
	local output
	output="$1"
	if [ -f "$output" ]; then
		tail -n 40 "$output" 2>/dev/null | sed 's/\\/\\\\/g; s/"/\\"/g; s/$/\\n/' | tr -d '\n'
	fi
}

luci_update_install_package() {
	local manager package output rc
	manager="$1"
	package="$2"
	output="$3"
	case "$manager" in
		opkg) opkg --force-reinstall install "$package" > "$output" 2>&1 ;;
		apk) apk add --allow-untrusted --force-overwrite "$package" > "$output" 2>&1 ;;
		*) return 1 ;;
	esac
	rc=$?
	return "$rc"
}

luci_clear_cache() {
	rm -f /tmp/luci-indexcache.*.json 2>/dev/null || true
	rm -rf /tmp/luci-modulecache /tmp/luci-templatecache 2>/dev/null || true
}

luci_schedule_service_reload() {
	(
		sleep 2
		/etc/init.d/rpcd restart >/dev/null 2>&1 || true
		/etc/init.d/uhttpd restart >/dev/null 2>&1 || true
	) >/dev/null 2>&1 &
}

luci_update_changed() {
	[ "$(jsonfilter -s "$1" -e '@.changed' 2>/dev/null)" = "true" ]
}

one_click_update_luci_changed() {
	[ "$(jsonfilter -s "$1" -e '@.luci.changed' 2>/dev/null)" = "true" ]
}

json_bool_required() {
	local file expr value code message
	file="$1"
	expr="$2"
	code="$3"
	message="$4"
	value="$(jsonfilter -i "$file" -e "$expr" 2>/dev/null || true)"
	case "$value" in
		true|false)
			printf '%s\n' "$value"
			return 0
			;;
	esac
	fail_with_details "$code" "$message" '"path":"'"$(json_escape "$file")"'","expr":"'"$(json_escape "$expr")"'","value":"'"$(json_escape "$value")"'"'
	return 1
}

core_update_check() {
	local arch tmpdir manifest asset_url asset_sha asset_version current_sha relation update_available
	log_line "localClash 核心更新检查：开始"
	if ! command -v jsonfilter >/dev/null 2>&1; then
		fail "jsonfilter_missing" "需要 jsonfilter 解析 localClash Release 清单。"
		return 1
	fi
	if ! command -v sha256sum >/dev/null 2>&1; then
		fail "sha256sum_missing" "需要 sha256sum 比对已安装 localClash 核心。"
		return 1
	fi
	if ! core_installed; then
		fail "bootstrap_core_missing" "localClash 核心尚未安装。"
		return 1
	fi
	arch="$(router_arch)" || {
		fail "unsupported_arch" "localClash 初始化助手不支持此路由器架构。"
		return 1
	}
	current_sha="$(sha256sum "$CORE" 2>/dev/null | awk '{print $1; exit}')"
	if [ -z "$current_sha" ]; then
		fail "core_checksum_failed" "无法计算已安装 localClash 核心的 sha256。"
		return 1
	fi
	tmpdir="$(mktemp -d /tmp/localclash-core-check.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建 localClash 核心更新检查临时目录。"
		return 1
	}
	manifest="$tmpdir/manifest.json"
	if ! fetch_manifest "$MANIFEST_URL" "$manifest"; then
		rm -rf "$tmpdir"
		fail "manifest_download_failed" "无法下载 localClash Release 清单。"
		return 1
	fi
	asset_url="$(jsonfilter -i "$manifest" -e "@.assets[@.arch=\"$arch\"].url" 2>/dev/null)"
	asset_sha="$(jsonfilter -i "$manifest" -e "@.assets[@.arch=\"$arch\"].sha256" 2>/dev/null)"
	asset_version="$(jsonfilter -i "$manifest" -e "@.version" 2>/dev/null)"
	if [ -z "$asset_url" ] || [ -z "$asset_sha" ]; then
		rm -rf "$tmpdir"
		fail "manifest_asset_missing" "Release 清单中没有匹配此路由器的 Linux 二进制文件。"
		return 1
	fi
	if [ -z "$asset_version" ]; then
		rm -rf "$tmpdir"
		fail "manifest_version_missing" "Release 清单中没有 localClash 版本号。"
		return 1
	fi
	rm -rf "$tmpdir"
	relation="asset_mismatch"
	update_available=true
	if [ "$current_sha" = "$asset_sha" ]; then
		relation="equal"
		update_available=false
	fi
	ok '"changed":false,"summary":"localClash 核心更新检查完成。","core":{"installed":true,"path":"'"$(json_escape "$CORE")"'","arch":"'"$(json_escape "$arch")"'","current_sha256":"'"$(json_escape "$current_sha")"'","latest_sha256":"'"$(json_escape "$asset_sha")"'","latest_version":"'"$(json_escape "$asset_version")"'","asset_url":"'"$(json_escape "$asset_url")"'"},"latest_version":"'"$(json_escape "$asset_version")"'","relation":"'"$(json_escape "$relation")"'","update_available":'"$update_available"',"checked_at":'"$(now_epoch)"
}

luci_update_check() {
	local manager tmpdir release asset_url asset_version current_version version_relation tag update_available
	log_line "LuCI 更新检查：开始"
	if ! command -v jsonfilter >/dev/null 2>&1; then
		fail "jsonfilter_missing" "需要 jsonfilter 解析 localclash-luci Release 信息。"
		return 1
	fi
	manager="$(luci_package_manager)" || {
		fail "package_manager_missing" "未检测到 opkg 或 apk，无法检查 LuCI 更新。"
		return 1
	}
	current_version="$(luci_installed_package_version "$manager")"
	if [ -z "$current_version" ]; then
		fail_with_details "luci_package_version_missing" "无法读取当前 LuCI 界面版本。" '"package_manager":"'"$(json_escape "$manager")"'"'
		return 1
	fi
	tmpdir="$(mktemp -d /tmp/localclash-luci-check.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建 LuCI 更新检查临时目录。"
		return 1
	}
	release="$tmpdir/latest.json"
	if ! fetch_url "$LUCI_RELEASE_API" "$release"; then
		rm -rf "$tmpdir"
		fail "luci_release_download_failed" "无法读取 localclash-luci 最新 Release。"
		return 1
	fi
	tag="$(jsonfilter -i "$release" -e '@.tag_name' 2>/dev/null)"
	asset_url="$(luci_update_asset_url "$release" "$manager")"
	if [ -z "$asset_url" ]; then
		rm -rf "$tmpdir"
		fail "luci_release_asset_missing" "最新 Release 中没有匹配当前包管理器的 LuCI 安装包。"
		return 1
	fi
	asset_version="$(luci_update_asset_version "$manager" "$asset_url")"
	if [ -z "$asset_version" ]; then
		rm -rf "$tmpdir"
		fail "luci_release_version_missing" "无法从最新 Release 安装包名称中识别 LuCI 版本。"
		return 1
	fi
	version_relation="$(luci_version_relation "$manager" "$current_version" "$asset_version")" || {
		rm -rf "$tmpdir"
		fail_with_details "luci_version_compare_failed" "无法比较当前 LuCI 版本和最新 Release 版本。" '"package_manager":"'"$(json_escape "$manager")"'","current_version":"'"$(json_escape "$current_version")"'","latest_version":"'"$(json_escape "$asset_version")"'"'
		return 1
	}
	rm -rf "$tmpdir"
	update_available=false
	[ "$version_relation" = "target_newer" ] && update_available=true
	ok '"changed":false,"summary":"LuCI 更新检查完成。","current_version":"'"$(json_escape "$current_version")"'","latest_version":"'"$(json_escape "$asset_version")"'","release_tag":"'"$(json_escape "$tag")"'","relation":"'"$(json_escape "$version_relation")"'","update_available":'"$update_available"',"checked_at":'"$(now_epoch)"',"luci_package":{"installed":true,"name":"luci-app-localclash","version":"'"$(json_escape "$current_version")"'","manager":"'"$(json_escape "$manager")"'","latest_url":"https://github.com/qoli/localclash-luci/releases/latest","release_api":"'"$(json_escape "$LUCI_RELEASE_API")"'"}}'
}

luci_update() {
	local manager tmpdir release asset_url asset_version current_version version_relation sha_url package sha_file expected actual install_log tag rc install_excerpt
	log_line "LuCI 更新：开始"
	if ! command -v jsonfilter >/dev/null 2>&1; then
		fail "jsonfilter_missing" "需要 jsonfilter 解析 localclash-luci Release 信息。"
		return 1
	fi
	manager="$(luci_package_manager)" || {
		fail "package_manager_missing" "未检测到 opkg 或 apk，无法自动更新 LuCI。"
		return 1
	}
	tmpdir="$(mktemp -d /tmp/localclash-luci-update.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建 LuCI 更新临时目录。"
		return 1
	}
	release="$tmpdir/latest.json"
	case "$manager" in
		opkg) package="$tmpdir/luci-app-localclash.ipk" ;;
		apk) package="$tmpdir/luci-app-localclash.apk" ;;
	esac
	sha_file="$tmpdir/luci-app-localclash.sha256"
	install_log="$tmpdir/install.log"
	log_line "LuCI 更新：正在读取最新 Release"
	if ! fetch_url "$LUCI_RELEASE_API" "$release"; then
		rm -rf "$tmpdir"
		fail "luci_release_download_failed" "无法读取 localclash-luci 最新 Release。"
		return 1
	fi
	tag="$(jsonfilter -i "$release" -e '@.tag_name' 2>/dev/null)"
	asset_url="$(luci_update_asset_url "$release" "$manager")"
	sha_url="$(luci_update_sha_url "$release" "$manager")"
	if [ -z "$asset_url" ] || [ -z "$sha_url" ]; then
		rm -rf "$tmpdir"
		fail "luci_release_asset_missing" "最新 Release 中没有匹配当前包管理器的 LuCI 安装包。"
		return 1
	fi
	asset_version="$(luci_update_asset_version "$manager" "$asset_url")"
	if [ -z "$asset_version" ]; then
		rm -rf "$tmpdir"
		fail "luci_release_version_missing" "无法从最新 Release 安装包名称中识别 LuCI 版本。"
		return 1
	fi
	current_version="$(luci_installed_package_version "$manager")"
	if [ -n "$current_version" ]; then
		version_relation="$(luci_version_relation "$manager" "$current_version" "$asset_version")" || {
			rm -rf "$tmpdir"
			fail_with_details "luci_version_compare_failed" "无法比较当前 LuCI 版本和最新 Release 版本。" '"package_manager":"'"$(json_escape "$manager")"'","current_version":"'"$(json_escape "$current_version")"'","target_version":"'"$(json_escape "$asset_version")"'"'
			return 1
		}
		if [ "$version_relation" = "equal" ]; then
			rm -rf "$tmpdir"
			log_line "LuCI 更新：当前版本 $current_version 已是最新"
			ok '"changed":false,"summary":"LuCI 界面已是最新版本。","current_version":"'"$(json_escape "$current_version")"'","latest_version":"'"$(json_escape "$asset_version")"'",'"$(luci_package_json)"
			return 0
		fi
		if [ "$version_relation" = "target_older" ]; then
			rm -rf "$tmpdir"
			log_line "LuCI 更新：当前版本 $current_version 高于最新 Release $asset_version"
			ok '"changed":false,"summary":"当前 LuCI 界面版本高于最新 Release，未执行降级。","current_version":"'"$(json_escape "$current_version")"'","latest_version":"'"$(json_escape "$asset_version")"'",'"$(luci_package_json)"
			return 0
		fi
	fi
	log_line "LuCI 更新：正在下载 ${tag:-latest} 校验文件"
	if ! fetch_url_direct_first "$sha_url" "$sha_file"; then
		rm -rf "$tmpdir"
		fail "luci_package_download_failed" "无法下载 LuCI 安装包校验文件。"
		return 1
	fi
	expected="$(awk '{print $1; exit}' "$sha_file" 2>/dev/null)"
	if [ -z "$expected" ]; then
		rm -rf "$tmpdir"
		fail "luci_package_checksum_failed" "LuCI 安装包校验文件为空或格式错误。"
		return 1
	fi
	log_line "LuCI 更新：正在下载 ${tag:-latest} 安装包"
	if ! fetch_url_verified_direct_first "$asset_url" "$package" "$expected"; then
		rm -rf "$tmpdir"
		fail_with_details "luci_package_checksum_failed" "LuCI 安装包下载失败或 sha256 校验失败，可能是 GitHub 镜像尚未同步最新 Release。" '"expected_sha":"'"$(json_escape "$expected")"'","target_version":"'"$(json_escape "$asset_version")"'"'
		return 1
	fi
	actual="$(sha256sum "$package" 2>/dev/null | awk '{print $1; exit}')"
	if [ -z "$actual" ] || [ "$expected" != "$actual" ]; then
		rm -rf "$tmpdir"
		fail_with_details "luci_package_checksum_failed" "LuCI 安装包 sha256 校验失败。" '"expected_sha":"'"$(json_escape "$expected")"'","actual_sha":"'"$(json_escape "$actual")"'","target_version":"'"$(json_escape "$asset_version")"'"'
		return 1
	fi
	log_line "LuCI 更新：sha256 校验通过，正在安装"
	luci_update_install_package "$manager" "$package" "$install_log"
	rc=$?
	if [ "$rc" -ne 0 ]; then
		install_excerpt="$(luci_install_log_excerpt "$install_log")"
		log_line "LuCI 更新：安装失败"
		if [ -n "$install_excerpt" ]; then
			log_line "LuCI 更新：安装输出摘要"
			tail -n 40 "$install_log" 2>/dev/null | while IFS= read -r line; do
				log_line "LuCI 更新：$line"
			done
		fi
		rm -rf "$tmpdir"
		fail_with_details "luci_package_install_failed" "LuCI 安装包安装失败，安装器输出已记录在任务日志中。" '"install_output":"'"$install_excerpt"'","package_manager":"'"$(json_escape "$manager")"'","target_version":"'"$(json_escape "$asset_version")"'","current_version":"'"$(json_escape "$current_version")"'"'
		return "$rc"
	fi
	luci_clear_cache
	rm -rf "$tmpdir"
	log_line "LuCI 更新：已完成"
	ok '"changed":true,"summary":"LuCI 界面已更新，请刷新浏览器页面。",'"$(luci_package_json)"
}

boot_restore_enable() {
	mkdir -p "$STATE_DIR" 2>/dev/null || true
	printf 'enabled\n' > "$BOOT_AUTO_RESTORE_FILE" 2>/dev/null || {
		fail "boot_restore_enable_failed" "无法启用开机自动恢复。"
		return 1
	}
	rm -f "$LEGACY_TAKEOVER_INTENT_FILE" 2>/dev/null || true
	ok '"changed":true,"summary":"开机自动恢复已启用。",'"$(boot_restore_json)"
}

boot_restore_disable() {
	rm -f "$BOOT_AUTO_RESTORE_FILE" "$LEGACY_TAKEOVER_INTENT_FILE" 2>/dev/null || true
	ok '"changed":true,"summary":"开机自动恢复已关闭。",'"$(boot_restore_json)"
}

now_epoch() {
	date +%s 2>/dev/null || printf '0\n'
}

write_task_running() {
	local summary task
	summary="$1"
	task="${2:-task}"
	printf '{"ok":true,"running":true,"done":false,"started_at":%s,"task":"%s","summary":"%s"}\n' "$(now_epoch)" "$(json_escape "$task")" "$(json_escape "$summary")" > "$TASK_STATUS"
}

write_task_pid() {
	[ -n "$1" ] || return 0
	printf '%s\n' "$1" > "$TASK_PID"
}

task_started_at() {
	jsonfilter -i "$TASK_STATUS" -e '@.started_at' 2>/dev/null || printf '0\n'
}

task_name() {
	jsonfilter -i "$TASK_STATUS" -e '@.task' 2>/dev/null || printf 'task\n'
}

task_pid_alive() {
	local pid
	[ -f "$TASK_PID" ] || return 1
	pid="$(cat "$TASK_PID" 2>/dev/null)"
	[ -n "$pid" ] || return 1
	kill -0 "$pid" 2>/dev/null
}

task_status_running() {
	[ "$(jsonfilter -i "$TASK_STATUS" -e '@.running' 2>/dev/null || true)" = "true" ]
}

write_task_done() {
	local rc result task started completed
	rc="$1"
	result="$2"
	task="$(task_name)"
	started="$(task_started_at)"
	completed="$(now_epoch)"
	case "$started" in
		""|*[!0-9]*) started=0 ;;
	esac
	printf '{"ok":true,"running":false,"done":true,"started_at":%s,"completed_at":%s,"task":"%s","exit_code":%s,"result":%s}\n' "$started" "$completed" "$(json_escape "$task")" "$rc" "$result" > "$TASK_STATUS"
}

lock_pid_alive() {
	local pid
	[ -f "$LOCK_DIR/pid" ] || return 1
	pid="$(cat "$LOCK_DIR/pid" 2>/dev/null)"
	[ -n "$pid" ] || return 1
	kill -0 "$pid" 2>/dev/null
}

clear_stale_lock() {
	[ -d "$LOCK_DIR" ] || return 0
	if ! lock_pid_alive; then
		rm -rf "$LOCK_DIR" 2>/dev/null || true
		log_line "任务锁：已清理失效任务锁"
	fi
}

clear_stale_task_pid() {
	[ -f "$TASK_PID" ] || return 0
	task_pid_alive && return 0
	rm -f "$TASK_PID" 2>/dev/null || true
}

write_task_stale_result() {
	local result task message action
	task="$(jsonfilter -i "$TASK_STATUS" -e '@.task' 2>/dev/null || true)"
	case "$task" in
		one_click_update)
			message="一键更新任务已中断，请重试。"
			action="点击一键更新重试。"
			;;
		runtime_start_takeover)
			message="运行时启动和网络接管任务已中断，请重试。"
			action="点击启动并接管重试。"
			;;
		bootstrap_core)
			message="localClash 核心更新任务已中断，请重试。"
			action="点击安装 / 更新核心重试。"
			;;
		bootstrap_default)
			message="初始化任务已中断，请重试。"
			action="点击一键初始化重试。"
			;;
		component_update)
			message="组件更新任务已中断，请重试。"
			action="点击对应组件更新按钮重试。"
			;;
		luci_update)
			message="LuCI 界面更新任务已中断，请重试。"
			action="点击检查 LuCI 更新重试。"
			;;
		subscription_set)
			message="订阅设置任务已中断，请重试。"
			action="重新保存订阅设置。"
			;;
		*)
			message="任务已中断，请重试。"
			action="重新执行刚才的操作。"
			;;
	esac
	result='{"ok":false,"code":"task_interrupted","message":"'"$(json_escape "$message")"'","details":{},"next_actions":["'"$(json_escape "$action")"'"]}'
	printf '%s\n' "$result" > "$TASK_RESULT"
	write_task_done 124 "$result"
}

reconcile_task_status() {
	local started age
	[ -f "$TASK_STATUS" ] || return 0
	task_status_running || return 0
	clear_stale_lock
	clear_stale_task_pid
	[ -d "$LOCK_DIR" ] && return 0
	task_pid_alive && return 0
	started="$(task_started_at)"
	age=$(( $(now_epoch) - started ))
	[ "$started" -gt 0 ] && [ "$age" -lt 10 ] && return 0
	if ! ps w 2>/dev/null | grep -q '[l]ocalclash .*_run'; then
		log_line "任务状态：检测到后台任务已中断"
		write_task_stale_result
	fi
}

with_lock() {
	waited=0
	while ! mkdir "$LOCK_DIR" 2>/dev/null; do
		clear_stale_lock
		if [ "$waited" -ge 120 ]; then
			log_line "等待任务锁超时：$*"
			fail "task_locked" "另一个 localClash 任务仍在运行，请稍后再试。"
			return 1
		fi
		waited=$((waited + 1))
		sleep 1
	done
	printf '%s\n' "$$" > "$LOCK_DIR/pid"
	trap 'rm -rf "$LOCK_DIR" 2>/dev/null || true' EXIT INT TERM
	"$@"
	rc=$?
	rm -rf "$LOCK_DIR" 2>/dev/null || true
	trap - EXIT INT TERM
	return "$rc"
}

child_pids() {
	local parent status pid ppid
	parent="$1"
	for status in /proc/[0-9]*/status; do
		[ -r "$status" ] || continue
		pid="$(awk '$1 == "Pid:" { print $2; exit }' "$status" 2>/dev/null)"
		ppid="$(awk '$1 == "PPid:" { print $2; exit }' "$status" 2>/dev/null)"
		[ "$ppid" = "$parent" ] && [ -n "$pid" ] && printf '%s\n' "$pid"
	done
}

kill_process_tree() {
	local signal pid child
	signal="$1"
	pid="$2"
	[ -n "$pid" ] || return 0
	for child in $(child_pids "$pid"); do
		kill_process_tree "$signal" "$child"
	done
	kill "$signal" "$pid" 2>/dev/null || true
}

task_cancel() {
	local pid lock_pid result killed
	killed=0
	reconcile_task_status
	if ! task_pid_alive && ! lock_pid_alive; then
		log_line "任务控制：没有正在运行的任务可中止"
		if [ -f "$TASK_STATUS" ]; then
			cat "$TASK_STATUS"
		else
			fail "task_not_running" "当前没有正在运行的 localClash 任务。"
		fi
		return 0
	fi
	log_line "任务控制：收到中止请求"
	if [ -f "$TASK_PID" ]; then
		pid="$(cat "$TASK_PID" 2>/dev/null)"
		if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
			kill_process_tree -TERM "$pid"
			killed=1
		fi
	fi
	if [ -f "$LOCK_DIR/pid" ]; then
		lock_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null)"
		if [ -n "$lock_pid" ] && [ "$lock_pid" != "$pid" ] && kill -0 "$lock_pid" 2>/dev/null; then
			kill_process_tree -TERM "$lock_pid"
			killed=1
		fi
	fi
	if [ "$killed" -eq 1 ]; then
		sleep 2
		[ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && kill_process_tree -KILL "$pid"
		[ -n "$lock_pid" ] && kill -0 "$lock_pid" 2>/dev/null && kill_process_tree -KILL "$lock_pid"
	fi
	rm -rf "$LOCK_DIR" 2>/dev/null || true
	rm -f "$TASK_PID" "$TASK_INPUT" 2>/dev/null || true
	result='{"ok":false,"code":"task_cancelled","message":"任务已中止。","details":{},"next_actions":["可以重新执行刚才的操作。"]}'
	printf '%s\n' "$result" > "$TASK_RESULT"
	write_task_done 130 "$result"
	log_line "任务控制：任务已中止"
	printf '%s\n' "$result"
}

run_with_heartbeat() {
	local label output tmp_output pid elapsed rc
	label="$1"
	output="$2"
	shift 2
	elapsed=0
	tmp_output="${output}.run.$$"
	rm -f "$tmp_output"
	( "$@" > "$tmp_output" ) &
	pid="$!"
	while kill -0 "$pid" 2>/dev/null; do
		sleep 5
		if kill -0 "$pid" 2>/dev/null; then
			elapsed=$((elapsed + 5))
			log_line "${label}：仍在执行（${elapsed}s）"
			if [ "$TASK_STEP_TIMEOUT" -gt 0 ] && [ "$elapsed" -ge "$TASK_STEP_TIMEOUT" ]; then
				log_line "${label}：超过 ${TASK_STEP_TIMEOUT}s，已停止等待"
				kill_process_tree -TERM "$pid"
				sleep 2
				kill_process_tree -KILL "$pid"
				wait "$pid" 2>/dev/null || true
				rm -f "$tmp_output"
				printf '{"ok":false,"code":"step_timeout","message":"%s 超时，请检查路由器是否能访问下载源，或稍后重试。","details":{"timeout_seconds":%s},"next_actions":["确认路由器可以访问下载源后重试。"]}\n' "$(json_escape "$label")" "$TASK_STEP_TIMEOUT" > "$output"
				return 124
			fi
		fi
	done
	wait "$pid"
	rc="$?"
	if [ -f "$tmp_output" ]; then
		mv "$tmp_output" "$output"
	else
		: > "$output"
	fi
	return "$rc"
}

fetch_single_url() {
	local url output
	url="$1"
	output="$2"
	if command -v uclient-fetch >/dev/null 2>&1; then
		fetch_with_watchdog "$url" uclient-fetch -T "$FETCH_TIMEOUT" -q -O "$output" "$url"
	elif command -v wget >/dev/null 2>&1; then
		fetch_with_watchdog "$url" wget -T "$FETCH_TIMEOUT" -q -O "$output" "$url"
	elif command -v curl >/dev/null 2>&1; then
		fetch_with_watchdog "$url" curl --max-time "$FETCH_TIMEOUT" -fsSL "$url" -o "$output"
	else
		return 1
	fi
}

fetch_with_watchdog() {
	local label pid watchdog elapsed rc
	label="$1"
	shift
	"$@" &
	pid="$!"
	(
		elapsed=0
		while kill -0 "$pid" 2>/dev/null; do
			sleep 5
			if kill -0 "$pid" 2>/dev/null; then
				elapsed=$((elapsed + 5))
				log_line "下载：等待 ${label}（${elapsed}s）"
				if [ "$elapsed" -ge "$FETCH_TIMEOUT" ]; then
					kill "$pid" 2>/dev/null || exit 0
					sleep 2
					kill -9 "$pid" 2>/dev/null || true
					exit 0
				fi
			fi
		done
	) &
	watchdog="$!"
	wait "$pid"
	rc="$?"
	kill "$watchdog" 2>/dev/null || true
	return "$rc"
}

probe_url_for_mirror() {
	local kind mirror
	kind="$1"
	mirror="$2"
	case "$kind:$mirror" in
		release:*)
			printf '%s/qoli/syncnext-api/main/pass.txt\n' "$(printf '%s' "$mirror" | sed 's#https://github.com#https://raw.githubusercontent.com#')"
			;;
		raw:https://fastly.jsdelivr.net/gh)
			printf 'https://fastly.jsdelivr.net/gh/qoli/syncnext-api@main/pass.txt\n'
			;;
		raw:*)
			printf '%s/qoli/syncnext-api/main/pass.txt\n' "$mirror"
			;;
	esac
}

mirror_probe_ok() {
	local kind mirror probe tmp body
	kind="$1"
	mirror="$2"
	probe="$(probe_url_for_mirror "$kind" "$mirror")"
	tmp="/tmp/localclash-mirror-probe.$$"
	rm -f "$tmp"
	log_line "下载：探测 $kind 镜像 $mirror"
	if ! fetch_single_url "$probe" "$tmp"; then
		rm -f "$tmp"
		return 1
	fi
	body="$(tr -d '\r\n' < "$tmp" 2>/dev/null)"
	rm -f "$tmp"
	[ "$body" = "pass" ]
}

select_github_mirror() {
	local kind mirrors mirror cache
	kind="$1"
	mirrors="$2"
	mkdir -p "$MIRROR_CACHE_DIR"
	cache="$MIRROR_CACHE_DIR/$kind"

	if [ -f "$cache" ]; then
		mirror="$(cat "$cache")"
		if [ -n "$mirror" ]; then
			printf '%s\n' "$mirror"
			return 0
		fi
	fi

	for mirror in $mirrors; do
		if mirror_probe_ok "$kind" "$mirror"; then
			printf '%s\n' "$mirror" > "$cache"
			log_line "下载：已选择 $kind 镜像 $mirror"
			printf '%s\n' "$mirror"
			return 0
		fi
	done

	rm -f "$cache"
	return 1
}

cache_github_mirror() {
	local kind mirror cache current
	kind="$1"
	mirror="$2"
	[ -n "$mirror" ] || return 0
	mkdir -p "$MIRROR_CACHE_DIR"
	cache="$MIRROR_CACHE_DIR/$kind"
	current="$(cat "$cache" 2>/dev/null || true)"
	if [ "$current" != "$mirror" ]; then
		printf '%s\n' "$mirror" > "$cache"
		log_line "下载：已确认 $kind 镜像 $mirror"
	fi
}

invalidate_github_mirror() {
	local kind mirror cache current
	kind="$1"
	mirror="$2"
	[ -n "$mirror" ] || return 0
	cache="$MIRROR_CACHE_DIR/$kind"
	current="$(cat "$cache" 2>/dev/null || true)"
	if [ "$current" = "$mirror" ]; then
		rm -f "$cache"
		log_line "下载：已丢弃 $kind 镜像 $mirror"
	fi
}

github_url_kind() {
	case "$1" in
		https://github.com/*) printf 'release\n' ;;
		https://raw.githubusercontent.com/*) printf 'raw\n' ;;
	esac
}

candidate_mirror_for_kind() {
	local kind candidate mirrors mirror
	kind="$1"
	candidate="$2"
	case "$kind" in
		release) mirrors="$GITHUB_RELEASE_MIRRORS" ;;
		raw) mirrors="$GITHUB_RAW_MIRRORS" ;;
		*) return 1 ;;
	esac
	for mirror in $mirrors; do
		case "$candidate" in
			"$mirror"/*)
				printf '%s\n' "$mirror"
				return 0
				;;
		esac
	done
	return 1
}

note_github_candidate_success() {
	local url candidate kind mirror
	url="$1"
	candidate="$2"
	kind="$(github_url_kind "$url")"
	[ -n "$kind" ] || return 0
	mirror="$(candidate_mirror_for_kind "$kind" "$candidate" || true)"
	cache_github_mirror "$kind" "$mirror"
}

note_github_candidate_failure() {
	local url candidate kind mirror
	url="$1"
	candidate="$2"
	kind="$(github_url_kind "$url")"
	[ -n "$kind" ] || return 0
	mirror="$(candidate_mirror_for_kind "$kind" "$candidate" || true)"
	invalidate_github_mirror "$kind" "$mirror"
}

raw_github_to_jsdelivr() {
	local rest owner repo branch path
	rest="${1#https://raw.githubusercontent.com/}"
	owner="${rest%%/*}"
	rest="${rest#*/}"
	repo="${rest%%/*}"
	rest="${rest#*/}"
	branch="${rest%%/*}"
	path="${rest#*/}"
	if [ -n "$owner" ] && [ -n "$repo" ] && [ -n "$branch" ] && [ -n "$path" ]; then
		printf 'https://fastly.jsdelivr.net/gh/%s/%s@%s/%s\n' "$owner" "$repo" "$branch" "$path"
	fi
}

github_download_candidates() {
	local url mirror selected
	url="$1"
	case "$GITHUB_MIRROR" in
		0|off|false|direct|none)
			printf '%s\n' "$url"
			return 0
			;;
	esac

	case "$url" in
		https://github.com/*)
			selected="$(select_github_mirror release "$GITHUB_RELEASE_MIRRORS" 2>/dev/null || true)"
			if [ -n "$selected" ]; then
				printf '%s%s\n' "$selected" "${url#https://github.com}"
			fi
			for mirror in $GITHUB_RELEASE_MIRRORS; do
				[ "$mirror" = "$selected" ] || printf '%s%s\n' "$mirror" "${url#https://github.com}"
			done
			;;
		https://raw.githubusercontent.com/*)
			selected="$(select_github_mirror raw "$GITHUB_RAW_MIRRORS" 2>/dev/null || true)"
			if [ -n "$selected" ]; then
				case "$selected" in
					https://fastly.jsdelivr.net/gh) raw_github_to_jsdelivr "$url" ;;
					*) printf '%s%s\n' "$selected" "${url#https://raw.githubusercontent.com}" ;;
				esac
			fi
			for mirror in $GITHUB_RAW_MIRRORS; do
				[ "$mirror" = "$selected" ] && continue
				case "$mirror" in
					https://fastly.jsdelivr.net/gh) raw_github_to_jsdelivr "$url" ;;
					*) printf '%s%s\n' "$mirror" "${url#https://raw.githubusercontent.com}" ;;
				esac
			done
			;;
	esac

	printf '%s\n' "$url"
}

fetch_url() {
	local url output tmp candidate
	url="$1"
	output="$2"
	tmp="$output.download.$$"
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			mv "$tmp" "$output"
			note_github_candidate_success "$url" "$candidate"
			return 0
		fi
		note_github_candidate_failure "$url" "$candidate"
		rm -f "$tmp"
	done
	return 1
}

fetch_url_direct_first() {
	local url output tmp candidate switched
	url="$1"
	output="$2"
	switched=false
	tmp="$output.download.$$"
	rm -f "$tmp"
	log_line "下载：尝试 $url"
	if fetch_single_url "$url" "$tmp"; then
		mv "$tmp" "$output"
		return 0
	fi
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		[ "$candidate" = "$url" ] && continue
		if [ "$switched" = false ]; then
			log_line "下载：正在切换 GitHub 镜像"
			switched=true
		fi
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			mv "$tmp" "$output"
			note_github_candidate_success "$url" "$candidate"
			return 0
		fi
		note_github_candidate_failure "$url" "$candidate"
		rm -f "$tmp"
	done
	return 1
}

fetch_manifest() {
	local url output tmp candidate
	url="$1"
	output="$2"
	tmp="$output.download.$$"
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			if jsonfilter -i "$tmp" -e '@.version' >/dev/null 2>&1; then
				mv "$tmp" "$output"
				note_github_candidate_success "$url" "$candidate"
				return 0
			fi
			log_line "下载：$candidate 返回的 Release 清单无效"
			note_github_candidate_failure "$url" "$candidate"
		else
			note_github_candidate_failure "$url" "$candidate"
		fi
		rm -f "$tmp"
	done
	return 1
}

fetch_url_verified_direct_first() {
	local url output expected_sha tmp candidate actual_sha switched
	url="$1"
	output="$2"
	expected_sha="$3"
	switched=false
	tmp="$output.download.$$"
	rm -f "$tmp"
	log_line "下载：尝试 $url"
	if fetch_single_url "$url" "$tmp"; then
		actual_sha="$(sha256sum "$tmp" | cut -d ' ' -f 1)"
		if [ "$actual_sha" = "$expected_sha" ]; then
			mv "$tmp" "$output"
			return 0
		fi
		log_line "下载：$url 校验和不匹配"
	fi
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		[ "$candidate" = "$url" ] && continue
		if [ "$switched" = false ]; then
			log_line "下载：正在切换 GitHub 镜像"
			switched=true
		fi
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			actual_sha="$(sha256sum "$tmp" | cut -d ' ' -f 1)"
			if [ "$actual_sha" = "$expected_sha" ]; then
				mv "$tmp" "$output"
				note_github_candidate_success "$url" "$candidate"
				return 0
			fi
			log_line "下载：$candidate 校验和不匹配"
			note_github_candidate_failure "$url" "$candidate"
		else
			note_github_candidate_failure "$url" "$candidate"
		fi
		rm -f "$tmp"
	done
	return 1
}

fetch_url_verified() {
	local url output expected_sha tmp candidate actual_sha
	url="$1"
	output="$2"
	expected_sha="$3"
	tmp="$output.download.$$"
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			actual_sha="$(sha256sum "$tmp" | cut -d ' ' -f 1)"
			if [ "$actual_sha" = "$expected_sha" ]; then
				mv "$tmp" "$output"
				note_github_candidate_success "$url" "$candidate"
				return 0
			fi
			log_line "下载：$candidate 校验和不匹配"
			note_github_candidate_failure "$url" "$candidate"
		else
			note_github_candidate_failure "$url" "$candidate"
		fi
		rm -f "$tmp"
	done
	return 1
}

