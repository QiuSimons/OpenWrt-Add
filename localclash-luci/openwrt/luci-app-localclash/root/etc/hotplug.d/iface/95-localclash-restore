#!/bin/sh

case "$ACTION" in
	ifup|ifupdate) ;;
	*) exit 0 ;;
esac

HELPER="${LOCALCLASH_HELPER:-/usr/libexec/rpcd/localclash}"
[ -x "$HELPER" ] || exit 0

STAMP="${LOCALCLASH_RESTORE_HOTPLUG_STAMP:-/tmp/localclash-restore-hotplug.stamp}"
RESTORE_DELAY="${LOCALCLASH_RESTORE_DELAY:-8}"
case "$RESTORE_DELAY" in
	''|*[!0-9]*) exit 1 ;;
esac

# Each interface event gets a unique generation token. The worker from an
# earlier event exits when a newer event has arrived, so restoration begins
# only after the final ifup/ifupdate event has been quiet for RESTORE_DELAY.
TOKEN="$$"
STAMP_TMP="${STAMP}.${TOKEN}"
umask 077
printf '%s\n' "$TOKEN" > "$STAMP_TMP" || exit 1
mv -f "$STAMP_TMP" "$STAMP" || exit 1

(
	sleep "$RESTORE_DELAY"
	LATEST_TOKEN="$(cat "$STAMP" 2>/dev/null)" || exit 1
	[ "$LATEST_TOKEN" = "$TOKEN" ] || exit 0
	"$HELPER" call takeover_restore >/dev/null 2>&1
) &
