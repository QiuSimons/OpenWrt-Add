{
	"luci-app-dae": {
		"description": "Grant access for luci-app-dae",
		"read": {
			"ubus": {
				"system": [ "board", "info" ],
				"service": [ "list" ],
				"rc": [ "list" ]
			},
			"uci": [ "dae" ],
			"file": [
				"/etc/dae/config.dae",
				"/etc/dae/config.d/dns.dae",
				"/etc/dae/config.d/node.dae",
				"/etc/dae/config.d/route.dae",
				"/var/log/dae/dae.log"
			]
		},
		"write": {
			"ubus": {
				"rc": [ "init" ]
			},
			"uci": [ "dae" ],
			"file": [
				"/etc/dae/config.dae",
				"/etc/dae/config.d/dns.dae",
				"/etc/dae/config.d/node.dae",
				"/etc/dae/config.d/route.dae",
				"/var/log/dae/dae.log"
			]
		}
	}
}
