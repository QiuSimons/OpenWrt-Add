#!/bin/sh /etc/rc.common

START=99

start() {
    mem_kb=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
    if [ "$mem_kb" -ge 4194304 ]; then
        t_max=134217728
    elif [ "$mem_kb" -ge 1048576 ]; then
        t_max=67108864
    else
        t_max=33554432
    fi

    sysctl -qw \
        net.core.somaxconn=65535 \
        net.ipv4.tcp_max_syn_backlog=16384 \
        net.core.netdev_max_backlog=16384 \
        net.core.rmem_max="$t_max" \
        net.core.wmem_max="$t_max" \
        net.ipv4.tcp_rmem="4096 87380 $t_max" \
        net.ipv4.tcp_wmem="4096 65536 $t_max"

    [ -f /proc/sys/net/ipv4/tcp_collapse_max_bytes ] && \
        sysctl -qw net.ipv4.tcp_collapse_max_bytes=4194304

    [ -d /sys/class/net/br-lan ] && \
        sysctl -qw net.ipv4.conf.br-lan.proxy_arp=1

    uci_changed=0
    for nic_path in /sys/class/net/*; do
        nic=$(basename "$nic_path")

        [ -d "$nic_path/device" ] || continue
        [ "$(cat "$nic_path/type" 2>/dev/null)" = "1" ] || continue

        uci_name=$(echo "$nic" | sed 's/[^a-zA-Z0-9_]/_/g; s/^[0-9]/_&/')

        if ! uci -q get "network.$uci_name" >/dev/null; then
            uci set "network.$uci_name=device"
            uci set "network.$uci_name.name=$nic"
            uci_changed=1
        fi

        if [ "$(uci -q get "network.$uci_name.gro")" != "1" ]; then
            uci set "network.$uci_name.gro=1"
            uci_changed=1
        fi

        ethtool -K "$nic" rx-checksum on 2>/dev/null || true
        ethtool -K "$nic" tx-checksum-ip-generic on 2>/dev/null || {
            ethtool -K "$nic" tx-checksum-ipv4 on 2>/dev/null || true
            ethtool -K "$nic" tx-checksum-ipv6 on 2>/dev/null || true
        }
        for f in sg tso ufo tx-scatter-gather; do
            ethtool -K "$nic" "$f" on 2>/dev/null || true
        done
    done

    if [ "$uci_changed" -eq 1 ]; then
        uci commit network
        ubus call network reload
    fi
}
